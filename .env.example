# ============================================
# KhetBuddy Environment Variables
# Copy to .env.local and fill in your values
# ============================================

# Supabase (required)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# AI: Disease Scan — Primary pipeline (Gemini Flash + DeepSeek)
# Get from: https://ai.google.dev (free tier: 1500 req/day)
GOOGLE_AI_API_KEY=your-google-ai-key

# Get from: https://platform.deepseek.com
DEEPSEEK_API_KEY=your-deepseek-key

# AI: Disease Scan — Fallback (Claude)
# Get from: https://console.anthropic.com
ANTHROPIC_API_KEY=your-anthropic-key

# Mandi Prices (optional — prices page won't show data without this)
# Register at: https://data.gov.in
DATA_GOV_IN_API_KEY=your-data-gov-in-key
